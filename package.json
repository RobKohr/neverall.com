{
  "name": "neverall.com",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:4001",
  "scripts": {
    "start": "BROWSER=firefox react-scripts --openssl-legacy-provider start",
    "build": "react-scripts build",
    "server": "nodemon --ignore '**/*.test.js' --watch 'server' -r dotenv/config server/server.js dotenv_config_path=.env",
    "build-and-serve": "npm run build; npm run server",
    "server-test": "node_modules/mocha/bin/mocha server/**/test.initialize.js server/**/*.test.js server/**/test.cleanup.js",
    "server-test-persist": "nodemon --watch 'server' --exec \"npm run server-test\" ",
    "react-test": "react-scripts test",
    "test": "npm run server-test",
    "eject": "react-scripts eject",
    "e2e": "./node_modules/.bin/cypress open",
    "lint": "eslint . --fix"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint"
    }
  },
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.1",
    "@testing-library/react": "^12.1.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/react-router-dom": "^5.3.2",
    "bcryptjs": "^2.4.3",
    "connect-mongodb-session": "^3.1.1",
    "dotenv": "^10.0.0",
    "express-session": "^1.17.2",
    "joi": "^17.5.0",
    "joi-to-swagger": "^6.0.1",
    "joigoose": "^8.0.2",
    "jsonwebtoken": "^8.5.1",
    "mocha": "^9.1.3",
    "mongoose": "^6.1.3",
    "node-fetch": "^3.1.0",
    "react": "^17.0.2",
    "react-cookie": "^4.1.1",
    "react-dom": "^17.0.2",
    "react-router-dom": "^6.2.1",
    "react-scripts": "^5.0.0",
    "sass": "^1.45.1",
    "swagger-jsdoc": "^6.1.0",
    "swagger-ui-express": "^4.1.6",
    "typescript": "^4.5.4",
    "universal-cookie": "^4.0.4",
    "uuid": "^8.3.2",
    "web-vitals": "^2.1.2"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/joigoose": "^2.0.6",
    "@types/react-dom": "^17.0.11",
    "@types/uuid": "^8.3.3",
    "husky": "^7.0.4",
    "lint-staged": "^12.1.4",
    "prettier": "^2.3.2"
  }
}
