{
  "name": "neverall.com",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:4001",
  "scripts": {
    "start": "BROWSER=firefox react-scripts start",
    "build": "react-scripts build",
    "server": "nodemon --ignore '**/*.test.js' --watch 'server' -r dotenv/config server/server.js dotenv_config_path=.env",
    "build-and-serve": "npm run build; npm run server",
    "server-test": "node_modules/mocha/bin/mocha server/**/test.initialize.js server/**/*.test.js server/**/test.cleanup.js",
    "server-test-persist": "nodemon --watch 'server' --exec \"npm run server-test\" ",
    "react-test": "react-scripts test",
    "test": "npm run server-test",
    "eject": "react-scripts eject",
    "e2e": "./node_modules/.bin/cypress open",
    "lint": "eslint . --fix"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint"
    }
  },
  "dependencies": {
    "14": "^1.0.1",
    "@reach/router": "^1.3.4",
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^11.1.0",
    "@testing-library/user-event": "^12.1.10",
    "@typescript-eslint/parser": "^4.30.0",
    "bcryptjs": "^2.4.3",
    "connect-mongodb-session": "^2.4.1",
    "dotenv": "^8.2.0",
    "eslint-config-airbnb-typescript-prettier": "^4.2.0",
    "express-session": "^1.17.2",
    "joi": "^17.4.0",
    "joi-to-swagger": "^5.2.0",
    "joigoose": "^8.0.1",
    "jsonwebtoken": "^8.5.1",
    "mocha": "^9.0.0",
    "mongoose": "^5.12.13",
    "node-fetch": "^2.6.1",
    "react": "^17.0.2",
    "react-cookie": "^4.0.3",
    "react-dom": "^17.0.2",
    "react-scripts": "^4.0.3",
    "sass": "^1.32.13",
    "swagger-jsdoc": "^6.1.0",
    "swagger-ui-express": "^4.1.6",
    "typescript": "^4.3.5",
    "universal-cookie": "^4.0.4",
    "uuid": "^3.4.0",
    "web-vitals": "^1.0.1"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/reach__router": "^1.3.9",
    "@types/uuid": "^8.3.1",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.24.2",
    "husky": "^7.0.2",
    "lint-staged": "^11.1.2"
  }
}
